<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Screening Dentale — Demo</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
  /* ─── CONFIG ─────────────────────────────────────────────── */
  :root {
    --bg:        #F7F5F1;
    --surface:   #FFFFFF;
    --ink:       #1A1A18;
    --ink2:      #5C5C56;
    --teal:      #2A6B6B;
    --teal-lt:   #3D8B8B;
    --gold:      #B8935A;
    --danger:    #C0443A;
    --radius:    16px;
    --shadow:    0 4px 32px rgba(26,26,24,.08);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  /* ─── CARD ───────────────────────────────────────────────── */
  .card {
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    width: 100%;
    max-width: 560px;
    overflow: hidden;
    position: relative;
  }

  /* progress bar */
  .progress-track {
    height: 3px;
    background: #E8E4DE;
    width: 100%;
  }
  .progress-fill {
    height: 100%;
    background: var(--teal);
    transition: width .5s ease;
  }

  .card-body {
    padding: 40px 44px 44px;
  }

  /* ─── STEP WRAPPER ───────────────────────────────────────── */
  .step { display: none; animation: fadeUp .4s ease; }
  .step.active { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── WELCOME ────────────────────────────────────────────── */
  .logo-mark {
    width: 48px; height: 48px;
    background: var(--teal);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 28px;
  }
  .logo-mark svg { width: 26px; height: 26px; fill: white; }

  .overline {
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--teal);
    font-weight: 500;
    margin-bottom: 10px;
  }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 36px;
    font-weight: 500;
    line-height: 1.15;
    margin-bottom: 16px;
    color: var(--ink);
  }

  .subtitle {
    font-size: 15px;
    color: var(--ink2);
    line-height: 1.6;
    margin-bottom: 36px;
  }

  .time-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #F0EDE8;
    border-radius: 100px;
    padding: 6px 14px;
    font-size: 13px;
    color: var(--ink2);
    margin-bottom: 36px;
  }
  .time-badge svg { width: 14px; height: 14px; opacity: .6; }

  /* ─── BTN ────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all .2s;
  }
  .btn-primary {
    background: var(--teal);
    color: white;
    width: 100%;
  }
  .btn-primary:hover { background: var(--teal-lt); transform: translateY(-1px); }
  .btn-secondary {
    background: transparent;
    color: var(--ink2);
    border: 1.5px solid #DDD9D2;
    font-size: 14px;
    padding: 10px 20px;
  }
  .btn-secondary:hover { border-color: var(--teal); color: var(--teal); }

  /* ─── QUESTIONS ──────────────────────────────────────────── */
  .q-counter {
    font-size: 12px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink2);
    margin-bottom: 10px;
  }
  .q-counter span { color: var(--teal); font-weight: 500; }

  h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .q-hint {
    font-size: 14px;
    color: var(--ink2);
    margin-bottom: 28px;
  }

  .choices { display: flex; flex-direction: column; gap: 10px; }

  .choice {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    border: 1.5px solid #E4E0D8;
    border-radius: 12px;
    cursor: pointer;
    transition: all .2s;
    font-size: 15px;
    background: transparent;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
    color: var(--ink);
  }
  .choice:hover {
    border-color: var(--teal);
    background: #F2F8F8;
  }
  .choice.selected {
    border-color: var(--teal);
    background: #EBF4F4;
    color: var(--teal);
  }
  .choice-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #F0EDE8;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    transition: background .2s;
  }
  .choice.selected .choice-icon { background: #D4EAEA; }

  .nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 28px;
  }

  /* ─── LOADING ────────────────────────────────────────────── */
  #step-loading { text-align: center; padding: 20px 0; }
  .spinner {
    width: 44px; height: 44px;
    border: 3px solid #E4E0D8;
    border-top-color: var(--teal);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 24px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ─── RESULT ─────────────────────────────────────────────── */
  .result-header {
    background: linear-gradient(135deg, var(--teal) 0%, #1E5050 100%);
    padding: 36px 44px 32px;
    color: white;
  }
  .result-header .overline { color: rgba(255,255,255,.6); }
  .result-header h1 { color: white; font-size: 30px; margin-bottom: 8px; }
  .result-header p { font-size: 14px; opacity: .8; line-height: 1.5; }

  .package-card {
    border: 2px solid var(--teal);
    border-radius: 12px;
    padding: 24px;
    margin: 28px 0;
    position: relative;
    overflow: hidden;
  }
  .package-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #EBF4F4 0%, transparent 60%);
    pointer-events: none;
  }
  .pkg-badge {
    display: inline-block;
    background: var(--teal);
    color: white;
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 12px;
  }
  .pkg-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--teal);
    margin-bottom: 8px;
  }
  .pkg-desc {
    font-size: 14px;
    color: var(--ink2);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .pkg-includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pkg-includes li {
    font-size: 14px;
    color: var(--ink);
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .pkg-includes li::before {
    content: '✓';
    color: var(--teal);
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .cta-block {
    background: #F7F5F1;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin-top: 8px;
  }
  .cta-block p {
    font-size: 14px;
    color: var(--ink2);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  /* email form */
  .email-row {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }
  .email-input {
    flex: 1;
    padding: 12px 16px;
    border: 1.5px solid #DDD9D2;
    border-radius: 10px;
    font-size: 15px;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    transition: border .2s;
  }
  .email-input:focus { border-color: var(--teal); }
  .btn-send {
    background: var(--teal);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 12px 20px;
    font-size: 14px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: background .2s;
    white-space: nowrap;
  }
  .btn-send:hover { background: var(--teal-lt); }
  .btn-send:disabled { opacity: .5; cursor: not-allowed; }

  .send-status {
    font-size: 13px;
    text-align: center;
    min-height: 20px;
    transition: color .2s;
  }
  .send-status.ok { color: var(--teal); }
  .send-status.err { color: var(--danger); }

  /* ─── SCORE PILLS ────────────────────────────────────────── */
  .score-row {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .score-pill {
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 100px;
    background: #F0EDE8;
    color: var(--ink2);
  }
  .score-pill.risk-low { background: #D4EAEA; color: var(--teal); }
  .score-pill.risk-med { background: #FBF0DC; color: #8A5E1A; }
  .score-pill.risk-high { background: #FADEDC; color: var(--danger); }

  /* demo banner */
  .demo-banner {
    background: var(--gold);
    color: white;
    text-align: center;
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 8px;
    font-weight: 500;
  }
</style>
</head>
<body>

<div class="card">
  <div class="demo-banner">Demo — Screening Interattivo</div>
  <div class="progress-track"><div class="progress-fill" id="progressBar" style="width:0%"></div></div>

  <div class="card-body">

    <!-- ── WELCOME ── -->
    <div class="step active" id="step-0">
      <div class="logo-mark">
        <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      </div>
      <div class="overline">Screening dentale gratuito</div>
      <h1>Scopri il piano di cura ideale per te</h1>
      <p class="subtitle">Rispondi a 6 brevi domande sulla tua salute orale. In meno di 2 minuti riceverai una valutazione personalizzata e il percorso di cura più adatto a te.</p>
      <div class="time-badge">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.49 2 2 6.49 2 12s4.49 10 10 10 10-4.49 10-10S17.51 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
        2 minuti · 6 domande · 100% gratuito
      </div>
      <button class="btn btn-primary" onclick="startQuiz()">
        Inizia lo screening
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <!-- ── QUESTIONS ── -->
    <div id="questions-container"></div>

    <!-- ── LOADING ── -->
    <div class="step" id="step-loading">
      <div class="spinner"></div>
      <p style="font-family:'Cormorant Garamond',serif; font-size:22px; font-weight:500; margin-bottom:8px;">Sto analizzando le tue risposte…</p>
      <p style="font-size:14px; color:var(--ink2);">Preparazione del tuo profilo di salute orale</p>
    </div>

    <!-- ── RESULT ── -->
    <div class="step" id="step-result"></div>

  </div>
</div>

<script>
// ─────────────────────────────────────────────────────────────
//  ⚙️  EMAILJS CONFIG — sostituisci con le tue credenziali
//      https://dashboard.emailjs.com
// ─────────────────────────────────────────────────────────────
const EMAILJS_PUBLIC_KEY        = "TUO_PUBLIC_KEY";            // Account → API Keys
const EMAILJS_SERVICE_ID        = "TUO_SERVICE_ID";            // Email Services
const EMAILJS_TEMPLATE_DENTIST  = "TUO_TEMPLATE_DENTISTA";    // template notifica a te
const EMAILJS_TEMPLATE_PATIENT  = "TUO_TEMPLATE_PAZIENTE";    // template conferma al paziente
const DENTIST_EMAIL             = "tua@email.it";              // ← la tua mail di ricezione

emailjs.init(EMAILJS_PUBLIC_KEY);

// ─────────────────────────────────────────────────────────────
//  DOMANDE
// ─────────────────────────────────────────────────────────────
const questions = [
  {
    id: "igiene",
    text: "Con quale frequenza ti lavi i denti?",
    hint: "Considera la media degli ultimi mesi",
    choices: [
      { label: "Almeno 2 volte al giorno",    emoji: "✨", score: 0 },
      { label: "Una volta al giorno",          emoji: "😊", score: 1 },
      { label: "Raramente o in modo irregolare", emoji: "😬", score: 2 },
    ]
  },
  {
    id: "filo",
    text: "Usi il filo interdentale o lo spazzolino interdentale?",
    hint: "Anche lo scovolino conta",
    choices: [
      { label: "Sì, ogni giorno",   emoji: "🦷", score: 0 },
      { label: "A volte",           emoji: "🤔", score: 1 },
      { label: "No, mai",           emoji: "😅", score: 2 },
    ]
  },
  {
    id: "gengive",
    text: "Ti sanguinano le gengive quando ti lavi i denti?",
    hint: "Anche un leggero sanguinamento è un segnale da non ignorare",
    choices: [
      { label: "No, mai",          emoji: "✅", score: 0 },
      { label: "A volte",          emoji: "⚠️", score: 1 },
      { label: "Spesso",           emoji: "🚨", score: 3 },
    ]
  },
  {
    id: "bruxismo",
    text: "Stringi o digrignii i denti di notte? Ti hanno mai parlato di bruxismo?",
    hint: "Mal di testa al mattino e usura dei denti sono segnali tipici",
    choices: [
      { label: "No, non ho mai avuto problemi", emoji: "😴", score: 0 },
      { label: "Non lo so, forse",              emoji: "🤷", score: 1 },
      { label: "Sì, me lo hanno già detto",     emoji: "😬", score: 2 },
    ]
  },
  {
    id: "visita",
    text: "Quando hai effettuato l'ultima visita dentistica?",
    hint: "Una visita di controllo ogni 6 mesi è raccomandata",
    choices: [
      { label: "Meno di 6 mesi fa",    emoji: "🗓️", score: 0 },
      { label: "6–12 mesi fa",         emoji: "📅", score: 1 },
      { label: "Più di 1 anno fa",     emoji: "⏳", score: 2 },
    ]
  },
  {
    id: "sensibilita",
    text: "Hai sensibilità ai cibi freddi, caldi o dolci?",
    hint: "Un dolore breve o prolungato al morso è rilevante",
    choices: [
      { label: "No, nessuna sensibilità",          emoji: "❄️", score: 0 },
      { label: "Lieve, ogni tanto",                emoji: "😐", score: 1 },
      { label: "Sì, forte e fastidiosa",            emoji: "😣", score: 3 },
    ]
  }
];

// ─────────────────────────────────────────────────────────────
//  PACCHETTI
// ─────────────────────────────────────────────────────────────
const packages = {
  base: {
    badge: "Mantenimento",
    name: "Pacchetto Sorriso Sano",
    desc: "Il tuo profilo di salute orale è buono. Ti consigliamo un percorso di mantenimento per preservare nel tempo i risultati raggiunti.",
    includes: [
      "Visita di controllo completa",
      "Igiene professionale (ablazione del tartaro)",
      "Consulenza personalizzata sull'igiene domiciliare",
      "Piano di follow-up semestrale"
    ],
    risk: "low"
  },
  medio: {
    badge: "Prevenzione",
    name: "Pacchetto Prevenzione Attiva",
    desc: "Sono emersi alcuni segnali da monitorare. Un percorso preventivo ti aiuterà a evitare che situazioni lievi diventino problematiche.",
    includes: [
      "Visita parodontale e sondaggio gengivale",
      "Igiene professionale approfondita",
      "Seduta di remineralizzazione",
      "Consulenza su bruxismo / bite (se indicato)",
      "Piano di controllo ogni 4 mesi"
    ],
    risk: "med"
  },
  alto: {
    badge: "Trattamento Completo",
    name: "Pacchetto Cura Integrata",
    desc: "Il tuo profilo suggerisce la necessità di un intervento più strutturato. Non preoccuparti: con il percorso giusto si risolve tutto.",
    includes: [
      "Visita diagnostica completa con RX panoramica",
      "Piano di trattamento personalizzato",
      "Igiene professionale e terapia parodontale",
      "Bite di scarico (se presente bruxismo)",
      "Trattamento della sensibilità dentinale",
      "Follow-up ravvicinato ogni 2–3 mesi"
    ],
    risk: "high"
  }
};

// ─────────────────────────────────────────────────────────────
//  STATE
// ─────────────────────────────────────────────────────────────
let currentQ    = 0;
let answers     = {};
let totalScore  = 0;

// ─────────────────────────────────────────────────────────────
//  RENDER
// ─────────────────────────────────────────────────────────────
function buildQuestions() {
  const container = document.getElementById('questions-container');
  questions.forEach((q, i) => {
    const div = document.createElement('div');
    div.className = 'step';
    div.id = `step-q${i}`;
    div.innerHTML = `
      <div class="q-counter">Domanda <span>${i+1}</span> di ${questions.length}</div>
      <h2>${q.text}</h2>
      <p class="q-hint">${q.hint}</p>
      <div class="choices">
        ${q.choices.map((c,ci) => `
          <button class="choice" onclick="selectChoice(${i},${ci},${c.score},'${c.label}')">
            <span class="choice-icon">${c.emoji}</span>
            ${c.label}
          </button>
        `).join('')}
      </div>
      <div class="nav-row">
        <button class="btn btn-secondary" onclick="goBack(${i})">← Indietro</button>
        <button class="btn btn-primary" id="next-btn-${i}" onclick="nextQuestion(${i})" disabled style="width:auto; opacity:.4; cursor:not-allowed;">
          ${i < questions.length - 1 ? 'Avanti →' : 'Vedi risultati →'}
        </button>
      </div>
    `;
    container.appendChild(div);
  });
}

function updateProgress() {
  const pct = ((currentQ + 1) / (questions.length + 2)) * 100;
  document.getElementById('progressBar').style.width = pct + '%';
}

function showStep(id) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ─────────────────────────────────────────────────────────────
//  FLOW
// ─────────────────────────────────────────────────────────────
function startQuiz() {
  buildQuestions();
  currentQ = 0;
  updateProgress();
  showStep('step-q0');
}

function selectChoice(qi, ci, score, label) {
  // deselect
  const choicesEl = document.querySelectorAll(`#step-q${qi} .choice`);
  choicesEl.forEach(c => c.classList.remove('selected'));
  choicesEl[ci].classList.add('selected');

  answers[questions[qi].id] = { score, label, qi };

  // enable next
  const btn = document.getElementById(`next-btn-${qi}`);
  btn.disabled = false;
  btn.style.opacity = '1';
  btn.style.cursor = 'pointer';
}

function nextQuestion(qi) {
  if (!answers[questions[qi].id]) return;
  if (qi < questions.length - 1) {
    currentQ = qi + 1;
    updateProgress();
    showStep(`step-q${currentQ}`);
  } else {
    // compute score
    totalScore = Object.values(answers).reduce((s, a) => s + a.score, 0);
    showLoading();
  }
}

function goBack(qi) {
  if (qi === 0) { showStep('step-0'); } 
  else { currentQ = qi - 1; updateProgress(); showStep(`step-q${currentQ}`); }
}

function showLoading() {
  document.getElementById('progressBar').style.width = '90%';
  showStep('step-loading');
  setTimeout(showResult, 2200);
}

// ─────────────────────────────────────────────────────────────
//  RESULT
// ─────────────────────────────────────────────────────────────
function getPackage() {
  if (totalScore <= 2) return packages.base;
  if (totalScore <= 6) return packages.medio;
  return packages.alto;
}

function getRiskLabel(risk) {
  if (risk === 'low')  return { text: 'Rischio basso',  cls: 'risk-low' };
  if (risk === 'med')  return { text: 'Rischio medio',  cls: 'risk-med' };
  return                      { text: 'Rischio elevato', cls: 'risk-high' };
}

function showResult() {
  const pkg  = getPackage();
  const risk = getRiskLabel(pkg.risk);

  // build answer pills
  const pillsHtml = Object.entries(answers).map(([k, v]) => {
    const q = questions.find(q => q.id === k);
    return `<span class="score-pill ${v.score >= 2 ? (v.score >= 3 ? 'risk-high' : 'risk-med') : 'risk-low'}">${q.id}</span>`;
  }).join('');

  const resultEl = document.getElementById('step-result');
  resultEl.innerHTML = `
    <div class="result-header">
      <div class="overline">Risultato del tuo screening</div>
      <h1>Abbiamo trovato il percorso per te</h1>
      <p>Basato sulle tue 6 risposte · Punteggio: ${totalScore}/14</p>
    </div>
    <div style="padding:32px 44px 40px;">
      <div class="score-row">
        <span class="score-pill ${risk.cls}">${risk.text}</span>
        ${pillsHtml}
      </div>
      <div class="package-card">
        <span class="pkg-badge">${pkg.badge}</span>
        <div class="pkg-name">${pkg.name}</div>
        <p class="pkg-desc">${pkg.desc}</p>
        <ul class="pkg-includes">
          ${pkg.includes.map(item => `<li>${item}</li>`).join('')}
        </ul>
      </div>
      <div class="cta-block">
        <p>Vuoi ricevere questo risultato via email e fissare una visita? Inserisci il tuo indirizzo qui sotto.</p>
        <div class="email-row">
          <input type="email" class="email-input" id="patientEmail" placeholder="la-tua@email.it">
          <button class="btn-send" id="sendBtn" onclick="sendEmail()">Invia →</button>
        </div>
        <div class="send-status" id="sendStatus"></div>
      </div>
    </div>
  `;

  document.getElementById('progressBar').style.width = '100%';
  showStep('step-result');
}

// ─────────────────────────────────────────────────────────────
//  EMAIL SEND
// ─────────────────────────────────────────────────────────────
function buildAnswerSummary() {
  return questions.map(q => {
    const ans = answers[q.id];
    return `• ${q.text}\n  → ${ans ? ans.label : '—'}`;
  }).join('\n\n');
}

async function sendEmail() {
  const emailInput = document.getElementById('patientEmail');
  const sendBtn    = document.getElementById('sendBtn');
  const statusEl   = document.getElementById('sendStatus');
  const pkg        = getPackage();
  const email      = emailInput.value.trim();

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    statusEl.textContent = 'Inserisci un indirizzo email valido.';
    statusEl.className   = 'send-status err';
    return;
  }

  sendBtn.disabled     = true;
  statusEl.textContent = 'Invio in corso…';
  statusEl.className   = 'send-status';

  const templateParams = {
    patient_email:   email,
    dentist_email:   DENTIST_EMAIL,
    pacchetto:       pkg.name,
    badge:           pkg.badge,
    punteggio:       totalScore,
    rischio:         pkg.risk === 'low' ? 'Basso' : pkg.risk === 'med' ? 'Medio' : 'Elevato',
    risposte:        buildAnswerSummary(),
    descrizione:     pkg.desc,
    servizi:         pkg.includes.join(', '),
  };

  if (EMAILJS_PUBLIC_KEY !== "TUO_PUBLIC_KEY") {
    try {
      // 1) Notifica al dentista
      await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_DENTIST, templateParams);
      // 2) Conferma al paziente
      await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_PATIENT, {
        ...templateParams,
        to_email: email,
      });
      statusEl.textContent = '✓ Perfetto! Controlla la tua email — ti abbiamo inviato il riepilogo.';
      statusEl.className   = 'send-status ok';
    } catch(err) {
      statusEl.textContent = 'Errore nell\'invio. Riprova tra qualche minuto.';
      statusEl.className   = 'send-status err';
      sendBtn.disabled     = false;
    }
  } else {
    console.log('📧 [DEMO] Dati da inviare:', templateParams);
    setTimeout(() => {
      statusEl.textContent = '✓ [DEMO] Configura EmailJS per l\'invio reale.';
      statusEl.className   = 'send-status ok';
    }, 800);
  }
}
</script>
